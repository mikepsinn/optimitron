{
  "name": "optomitron",
  "version": "0.1.0",
  "private": true,
  "description": "AI governance platform: causal inference, preference aggregation, health tracking, optimal policy & budget generation",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikepsinn/optomitron.git"
  },
  "author": "Mike P. Sinn <m@thinkbynumbers.org>",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "db:generate": "pnpm --filter @optomitron/db prisma generate",
    "db:migrate": "pnpm --filter @optomitron/db prisma migrate dev",
    "db:push": "pnpm --filter @optomitron/db prisma db push"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@8.14.0",
  "engines": {
    "node": ">=18"
  }
}
